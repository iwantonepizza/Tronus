# =============================================================================
# Tronus — backend production environment
# Скопируй этот файл в backend.prod.env и заполни все REPLACE_ME значения.
# НЕ коммить backend.prod.env в git!
# =============================================================================

DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=CRe-5jcqkBiqncM1ugwF1A2dRFogdUFzeS-SCak--XAbYFUBZ_Cs-nwfXm94kfFv1cq9irVIK5XSr8qC

DEBUG=False

# Домены или IP сервера, без схемы. Через запятую.
# Пример: ALLOWED_HOSTS=tronus.example.com,1.2.3.4
ALLOWED_HOSTS=got.craft-hookah.ru

# -----------------------------------------------------------------------
# PostgreSQL (контейнер db в docker-compose.prod.yml)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://tronus:PizzaUsr202@db:5432/tronus

POSTGRES_DB=tronus
POSTGRES_USER=tronus
POSTGRES_PASSWORD=PizzaUsr202

# -----------------------------------------------------------------------
# CORS / CSRF
# -----------------------------------------------------------------------
# CORS_ALLOWED_ORIGINS:
#   - Если фронт и бэк на ОДНОМ домене (host-nginx сценарий) — оставь ПУСТЫМ.
#     Same-origin запросы не требуют CORS.
#   - Если фронт на отдельном поддомене (api.example.com vs app.example.com) —
#     укажи URL фронта: https://app.example.com
CORS_ALLOWED_ORIGINS=

# CSRF_TRUSTED_ORIGINS — обязательно. URL, с которого браузер открывает приложение.
# Через запятую. С СХЕМОЙ (https://...).
# Пример: CSRF_TRUSTED_ORIGINS=https://tronus.example.com
CSRF_TRUSTED_ORIGINS=https://got.craft-hookah.ru

SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# -----------------------------------------------------------------------
# Secure cookies — ВКЛЮЧИ КОГДА НАСТРОИШЬ HTTPS (через certbot)
# -----------------------------------------------------------------------
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=1

# -----------------------------------------------------------------------
# Приложение
# -----------------------------------------------------------------------
# Секретное слово для регистрации (без него — pending_approval).
# Регистр не важен (case-insensitive в коде).
REGISTRATION_SECRET_WORD=lovecraft

# -----------------------------------------------------------------------
# Bind-mount пути (для docker-compose.prod.yml host-nginx сценария)
# -----------------------------------------------------------------------
# По умолчанию используются /var/www/tronus/static и /var/www/tronus/media.
# Если хочешь другой путь — раскомментируй и укажи.
# TRONUS_STATIC_PATH=/var/www/tronus/static
# TRONUS_MEDIA_PATH=/var/www/tronus/media
