# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/got_tracker

# CSRF / CORS (для интеграции с фронтом на Vite :5173)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8008,http://localhost:8008,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookies (Lax подходит для dev на localhost)
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Prod-only (не обязательно для dev)
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
